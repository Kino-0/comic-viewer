{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "mirror-*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "core:window:default",
    "core:window:allow-create",
    "core:event:default",
    "core:webview:allow-create-webview-window"
  ]
}
